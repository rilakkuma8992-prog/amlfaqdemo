<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AML FAQ 互動原型 Demo</title>
<link rel="stylesheet" href="css/style.css">
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <div class="brand-area">
      <div class="logo-slot">
        <img src="assets/cathay-logo.png" alt="國泰世華銀行 Cathay United Bank">
      </div>
      <div class="buddy-title">AML FAQ</div>
    </div>
    <div class="top-actions">
      <div class="language-switch" aria-label="語言切換">
        <button class="language-option" type="button" data-lang-option="en">EN</button>
        <span aria-hidden="true">／</span>
        <button class="language-option is-active" type="button" data-lang-option="zh">中</button>
      </div>
      <button class="contact-top" type="button" onclick="openContactModal()">聯絡洗防窗口</button>
    </div>
  </div>
</header>

<main class="page-shell">
  <div class="desktop-app" id="app"></div>
</main>

<div id="modalLayer"></div>

<script src="js/data.js"></script>
<script src="js/app.js"></script>
</body>
</html>
